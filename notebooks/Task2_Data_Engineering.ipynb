   "source": [
    "# Task 2: Data Engineering\n",
    "\n",
    "**Objective:** Prepare the airline dataset for machine learning by cleaning data, handling missing values, removing duplicates and irrelevant records, eliminating leakage variables and identifiers, and selecting appropriate features as specified in the assignment requirements.\n",
    "\n",
    "This notebook focuses on data preparation steps including removing duplicates, handling missing values, filtering cancelled/diverted flights, eliminating leakage variables, and feature selection for the flight delay prediction model."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Methodology\n",
    "\n",
    "1. Load the dataset from Task 1\n",
    "2. Remove duplicate records\n",
    "3. Handle missing values appropriately for different data types\n",
    "4. Remove cancelled and diverted flights (Cancelled == 0, Diverted == 0)\n",
    "5. Eliminate leakage variables: ArrDelay, ArrDelayMinutes, ArrivalDelayGroups, ArrTime, ArrTimeBlk\n",
    "6. Exclude identifier columns: Tail_Number, Flight_Number_Reporting_Airline, FlightDate\n",
    "7. Select features as specified:\n",
    "   - Numerical: Month, DayOfWeek, CRSDepTime, DepDelay, TaxiOut, Distance, AirTime\n",
    "   - Categorical: Reporting_Airline, Origin, Dest\n",
    "   - Target: ArrDel15\n",
    "8. Implement sampling strategy for training on 15% stratified sample\n",
    "9. Provide interpretation notes for academic report"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "tags": [
     "setup"
    ]
   },
   "outputs": [],
   "source": [
    "# Import necessary libraries\n",
    "from pyspark.sql import SparkSession\n",
    "from pyspark.sql.functions import *\n",
    "from pyspark.sql.types import *\n",
    "from pyspark.ml.feature import StringIndexer, OneHotEncoder, VectorAssembler, StandardScaler\n",
    "from pyspark.ml import Pipeline\n",
    "import os\n",
    "\n",
    "# Initialize Spark Session\n",
    "spark = SparkSession.builder \\\n",
    "    .appName(\"7006SCN-Task2-DataEngineering\") \\\n",
    "    .config(\"spark.sql.adaptive.enabled\", \"true\") \\\n",
    "    .config(\"spark.sql.adaptive.coalescePartitions.enabled\", \"true\") \\\n",
    "    .getOrCreate()\n",
    "\n",
    "# Set log level\n",
    "spark.sparkContext.setLogLevel(\"WARN\")\n",
    "\n",
    "# Configure data path\n",
    "DATA_PATH = \"data/On_Time_Reporting_Carrier_On_Time_Performance_2024_1.csv\"\n",
    "\n",
    "# Load dataset\n",
    "print(\"Loading dataset...\")\n",
    "df = spark.read \\\n",
    "    .option(\"header\", \"true\") \\\n",
    "    .option(\"inferSchema\", \"true\") \\\n",
    "    .option(\"nullValue\", \"\") \\\n",
    "    .option(\"treatEmptyValuesAsNulls\", \"true\") \\\n",
    "    .csv(DATA_PATH)\n",
    "\n",
    "print(f\"Initial dataset: {df.count():,} rows, {len(df.columns)} columns\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "tags": [
     "data-preparation"
    ]
   },
   "outputs": [],
   "source": [
    "# Step 1: Remove duplicate records\n",
    "print(\"\\nStep 1: Removing duplicate records...\")\n",
    "initial_count = df.count()\n",
    "df_dedup = df.dropDuplicates()\n",
    "dedup_count = df_dedup.count()\n",
    "duplicates_removed = initial_count - dedup_count\n",
    "print(f\"Duplicates removed: {duplicates_removed:,}\")\n",
    "print(f\"Records after deduplication: {dedup_count:,}\")\n",
    "\n",
    "# Step 2: Handle missing values\n",
    "print(\"\\nStep 2: Handling missing values...\")\n",
    "\n",
    "# Analyze missing values before handling\n",
    "print(\"Missing values before handling:\")\n",
    "missing_before = df_dedup.select([count(when(col(c).isNull(), c)).alias(c) for c in df_dedup.columns])\n",
    "missing_before.show()\n",
    "\n",
    "# Define strategies for different column types\n",
    "# Numerical columns: fill with median\n",
    "# Categorical columns: fill with mode or 'Unknown'\n",
    "\n",
    "# Identify column types\n",
    "numerical_cols = [field.name for field in df_dedup.schema.fields if isinstance(field.dataType, (IntegerType, LongType, FloatType, DoubleType))]\n",
    "string_cols = [field.name for field in df_dedup.schema.fields if isinstance(field.dataType, StringType)]\n",
    "\n",
    "print(f\"Numerical columns ({len(numerical_cols)}): {numerical_cols[:5]}{'...' if len(numerical_cols) > 5 else ''}\")\n",
    "print(f\"String columns ({len(string_cols)}): {string_cols[:5]}{'...' if len(string_cols) > 5 else ''}\")\n",
    "\n",
    "# Handle numerical columns - fill with median\n",
    "df_filled = df_dedup\n",
    "for col_name in numerical_cols:\n",
    "    if col_name in df_dedup.columns:\n",
    "        median_val = df_dedup.approxQuantile(col_name, [0.5], 0.25)[0]\n",
    "        if median_val is not None:\n",
    "            df_filled = df_filled.fillna({col_name: median_val})\n",
    "        else:\n",
    "            df_filled = df_filled.fillna({col_name: 0})\n",
    "\n",
    "# Handle string columns - fill with 'Unknown'\n",
    "for col_name in string_cols:\n",
    "    if col_name in df_dedup.columns:\n",
    "        df_filled = df_filled.fillna({col_name: \"Unknown\"})\n",
    "\n",
    "# Verify missing values after handling\n",
    "print(\"\\nMissing values after handling:\")\n",
    "missing_after = df_filled.select([count(when(col(c).isNull(), c)).alias(c) for c in df_filled.columns])\n",
    "missing_after.show()\n",
    "\n",
    "total_missing_before = missing_before.select(sum(*[col(c) for c in df_dedup.columns])).collect()[0][0]\n",
    "total_missing_after = missing_after.select(sum(*[col(c) for c in df_filled.columns])).collect()[0][0]\n",
    "print(f\"\\nTotal missing values before: {total_missing_before:,}\")\n",
    "print(f\"Total missing values after: {total_missing_after:,}\")\n",
    "print(f\"Missing values handled: {total_missing_before - total_missing_after:,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "tags": [
     "data-preparation"
    ]
   },
   "outputs": [],
   "source": [
    "# Step 3: Remove cancelled and diverted flights\n",
    "print(\"\\nStep 3: Removing cancelled and diverted flights...\")\n",
    "initial_count = df_filled.count()\n",
    "df_filtered = df_filled.filter((col(\"Cancelled\") == 0) & (col(\"Diverted\") == 0))\n",
    "filtered_count = df_filtered.count()\n",
    "removed_count = initial_count - filtered_count\n",
    "print(f\"Records removed (cancelled/diverted): {removed_count:,}\")\n",
    "print(f\"Records after filtering: {filtered_count:,}\")\n",
    "\n",
    "# Show distribution of cancelled and diverted flights for reference\n",
    "print(\"\\nDistribution of cancelled and diverted flights:\")\n",
    "df_filled.groupBy(\"Cancelled\", \"Diverted\").count().show()\n",
    "\n",
    "# Step 4: Eliminate leakage variables\n",
    "print(\"\\nStep 4: Eliminating leakage variables...\")\n",
    "leakage_vars = [\"ArrDelay\", \"ArrDelayMinutes\", \"ArrivalDelayGroups\", \"ArrTime\", \"ArrTimeBlk\"]\n",
    "print(f\"Leakage variables to remove: {leakage_vars}\")\n",
    "\n",
    "# Check which leakage variables exist in the dataset\n",
    "existing_leakage = [var for var in leakage_vars if var in df_filtered.columns]\n",
    "print(f\"Existing leakage variables: {existing_leakage}\")\n",
    "\n",
    "df_no_leakage = df_filtered.drop(*existing_leakage)\n",
    "print(f\"Columns after removing leakage: {len(df_no_leakage.columns)} (was {len(df_filtered.columns)})\")\n",
    "\n",
    "# Step 5: Exclude identifier columns\n",
    "print(\"\\nStep 5: Excluding identifier columns...\")\n",
    "identifier_cols = [\"Tail_Number\", \"Flight_Number_Reporting_Airline\", \"FlightDate\"]\n",
    "print(f\"Identifier columns to remove: {identifier_cols}\")\n",
    "\n",
    "# Check which identifier columns exist\n",
    "existing_identifiers = [col for col in identifier_cols if col in df_no_leakage.columns]\n",
    "print(f\"Existing identifier columns: {existing_identifiers}\")\n",
    "\n",
    "df_clean = df_no_leakage.drop(*existing_identifiers)\n",
    "print(f\"Columns after removing identifiers: {len(df_clean.columns)} (was {len(df_no_leakage.columns)})\")\n",
    "\n",
    "# Step 6: Select features as specified\n",
    "print(\"\\nStep 6: Selecting features as specified...\")\n",
    "\n",
    "# Define feature sets as required\n",
    "numeric_features = [\"Month\", \"DayOfWeek\", \"CRSDepTime\", \"DepDelay\", \"TaxiOut\", \"Distance\", \"AirTime\"]\n",
    "categorical_features = [\"Reporting_Airline\", \"Origin\", \"Dest\"]\n",
    "label_column = \"ArrDel15\"\n",
    "\n",
    "print(f\"Numerical features: {numeric_features}\")\n",
    "print(f\"Categorical features: {categorical_features}\")\n",
    "print(f\"Target variable: {label_column}\")\n",
    "\n",
    "# Verify all required features exist\n",
    "missing_numeric = [f for f in numeric_features if f not in df_clean.columns]\n",
    "missing_categorical = [f for f in categorical_features if f not in df_clean.columns]\n",
    "missing_label = [f for f in [label_column] if f not in df_clean.columns]\n",
    "\n",
    "if missing_numeric:\n",
    "    print(f\"WARNING: Missing numerical features: {missing_numeric}\")\n",
    "if missing_categorical:\n",
    "    print(f\"WARNING: Missing categorical features: {missing_categorical}\")\n",
    "if missing_label:\n",
    "    print(f\"ERROR: Missing label column: {missing_label}\")\n",
    "    raise Exception(\"Required label column not found\")\n",
    "\n",
    "# Select only the required columns plus target\n",
    "required_columns = numeric_features + categorical_features + [label_column]\n",
    "df_selected = df_clean.select(required_columns)\n",
    "\n",
    "print(f\"Final dataset shape: {df_selected.count():,} rows, {len(df_selected.columns)} columns\")\n",
    "print(f\"Selected columns: {df_selected.columns}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "tags": [
     "sampling"
    ]
   },
   "outputs": [],
   "source": [
    "# Step 7: Implement sampling strategy\n",
    "print(\"\\nStep 7: Implementing sampling strategy...\")\n",
    "\n",
    "# Check class distribution before sampling\n",
    "print(\"Class distribution before sampling:\")\n",
    "df_selected.groupBy(label_column).count().show()\n",
    "\n",
    "# Perform stratified sampling: 15% of each class\n",
    "print(\"Performing stratified sampling (15% of each class)...\")\n",
    "sampled_df = df_selected.sampleBy(\n",
    "    label_column,\n",
    "    fractions={0: 0.15, 1: 0.15},\n",
    "    seed=42\n",
    ")\n",
    "\n",
    "sampled_count = sampled_df.count()\n",
    "original_count = df_selected.count()\n",
    "print(f\"Original dataset size: {original_count:,}\")\n",
    "print(f\"Sampled dataset size: {sampled_count:,}\")\n",
    "print(f\"Sampling ratio: {sampled_count/original_count*100:.1f}%\")\n",
    "\n",
    "# Verify class distribution after sampling\n",
    "print(\"\\nClass distribution after sampling:\")\n",
    "sampled_df.groupBy(label_column).count().show()\n",
    "\n",
    "# Calculate sampling fractions\n",
    "original_dist = df_selected.groupBy(label_column).agg(count(\"*\").alias(\"count\"))\n",
    "sampled_dist = sampled_df.groupBy(label_column).agg(count(\"*\").alias(\"count\"))\n",
    "\n",
    "print(\"\\nSampling verification:\")\n",
    "original_dist.join(sampled_dist, label_column, \"inner\") \\\n",
    "    .withColumn(\"sampling_ratio\", col(\"count\") / col(\"count\")) \\\n",
    "    .show()\n",
    "\n",
    "# Use sampled dataset for further processing\n",
    "df_processed = sampled_df.cache()\n",
    "print(f\"\\nProcessed dataset cached: {df_processed.count():,} rows\")\n",
    "\n",
    "# Show basic statistics of processed data\n",
    "print(\"\\nBasic statistics of processed data:\")\n",
    "df_processed.describe().show()"
   ]
  },
