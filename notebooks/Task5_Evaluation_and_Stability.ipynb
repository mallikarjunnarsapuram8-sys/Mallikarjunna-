    "\n",
    "stability_scores = {}\n",
    "\n",
    "for model_name in model_results.keys():\n",
    "    if model_name in perturbed_results:\n",
    "        # Calculate stability based on AUC change (most representative metric)\n",
    "        original_auc = model_results[model_name][\"auc\"]\n",
    "        perturbed_auc = perturbed_results[model_name][\"auc\"]\n",
    "        auc_change = abs(original_auc - perturbed_auc)\n",
    "        auc_change_pct = (auc_change / original_auc) * 100 if original_auc > 0 else 0\n",
    "        \n",
    "        # Stability score: lower change = higher stability\n",
    "        stability_score = 100 - auc_change_pct  # Higher is more stable\n",
    "        stability_scores[model_name] = stability_score\n",
    "        \n",
    "        change_direction = \"↓\" if perturbed_auc < original_auc else \"↑\"\n",
    "        \n",
    "        print(f\"{model_name:<20} {\"AUC-ROC\":<12} {original_auc:<12.4f} {perturbed_auc:<12.4f} {change_direction}{auc_change_pct:<11.2f}% {stability_score:<12.2f}\")\n",
