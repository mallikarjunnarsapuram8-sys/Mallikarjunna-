   "source": [
    "## Stability Analysis\n",
    "\n",
    "Conduct stability analysis through dataset perturbation as required."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "tags": [
     "stability"
    ]
   },
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# STABILITY ANALYSIS THROUGH PERTURBATION\n",
    "# ============================================================================\n",
    "\n",
    "print(\"\\n=== STABILITY ANALYSIS ===\")\n",
    "print(\"Analyzing model stability through dataset perturbation...\")\n",
    "\n",
    "# Create perturbed dataset by removing 5% of rows\n",
    "print(\"Creating perturbed dataset by removing 5% of rows...\")\n",
    "\n",
    "# Remove 5% of rows randomly (not stratified to simulate real-world perturbations)\n",
    "perturbed_df = train_data.sample(False, 0.95, seed=42)  # Keep 95%, remove 5%\n",
    "original_count = train_data.count()\n",
    "perturbed_count = perturbed_df.count()\n",
    "removed_count = original_count - perturbed_count\n",
    "\n",
    "print(f\"Original training set size: {original_count:,} rows\")\n",
    "print(f\"Perturbed training set size: {perturbed_count:,} rows\")\n",
    "print(f\"Rows removed: {removed_count:,} ({removed_count/original_count*100:.1f}%)\")\n",
    "\n",
    "# Check class distribution in perturbed dataset\n",
    "print(\"\\nClass distribution comparison:\")\n",
    "print(\"Original training set:\")\n",
    "train_data.groupBy(label_column).count().show()\n",
    "\n",
    "print(\"Perturbed training set:\")\n",
    "perturbed_df.groupBy(label_column).count().show()\n",
    "\n",
    "# Split perturbed data into training and test (using same test set for fair comparison)\n",
    "perturbed_train_data, perturbed_val_data = perturbed_df.randomSplit([0.8, 0.2], seed=42)\n",
    "perturbed_train_data.cache()\n",
    "perturbed_val_data.cache()\n",
    "\n",
    print(f\"Perturbed training set: {perturbed_train_data.count():,} rows\")\n",
    print(f\"Perturbed validation set: {perturbed_val_data.count():,} rows\")\n,
    "\n",
    "# Retrain models on perturbed dataset\n",
    "print(\"\\nRetraining models on perturbed dataset...\")\n",
    "\n",
    "perturbed_results = {}\n",
    "perturbed_models = {}\n",
    "\n",
    "for model_name, classifier in classifiers.items():\n",
